{
  "name": "scoring-figure-skating-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "client": "npm run dev --workspace=client",
    "server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "prettier": "^3.8.1"
  }
}
